{
  "name": "pharmacovigilence-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend/apps/*",
    "backend/packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "dev:backend": "npm run dev:api --workspace=backend",
    "test:backend": "npm test --workspace=backend",
    "seed:backend": "npm run seed --workspace=backend"
  }
}
