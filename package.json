{
  "name": "pharmacovigilence-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend/apps/*",
    "backend/packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "dev:backend": "npm run dev:api --workspace=backend",
    "test:backend": "npm test --workspace=backend",
    "seed:backend": "npm run seed --workspace=backend"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.23",
    "@supabase/supabase-js": "^2.39.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.19.0",
    "uuid": "^9.0.1",
    "ws": "^8.21.1",
    "zod": "^3.23.8"
  }
}
